# Supabase — タイムライン・課金・ログイン用（https://supabase.com で無料作成）
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase Auth: Dashboard → Authentication → URL Configuration
# Site URL: https://tsugi-bato.pages.dev  （localhost:3000 ではない！）
# Redirect URLs: https://tsugi-bato.pages.dev/login , http://localhost:5173/login
# Providers: Email (magic link) ON / Google ON（使う場合）
VITE_SITE_URL=https://tsugi-bato.pages.dev

# 課金（Stripe + Supabase Edge Functions）
# フロント: VITE_BILLING_ENABLED=true で本番決済UIを有効化
VITE_BILLING_ENABLED=false
# ローカル開発のみ: Stripe テスト契約を Pro 扱い（localhost + true のときだけ）
# VITE_BILLING_ALLOW_TEST=true

# 特定商取引法・問い合わせ（本番公開前に必須）
VITE_LEGAL_OPERATOR_NAME=事業者名
VITE_LEGAL_REPRESENTATIVE=代表者名
# 自宅住所をサイトに載せない場合（省略規定）: true にすると表記ページに開示請求の文言を表示
VITE_LEGAL_USE_ADDRESS_OMISSION=true
VITE_LEGAL_ADDRESS=都道府県市区町村以降の住所
VITE_LEGAL_PHONE=03-0000-0000
VITE_LEGAL_EMAIL=support@example.com

# Supabase Edge Functions のシークレット（supabase secrets set で設定）
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...   # 月額500円の Price ID
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY=...  # Edge Functions 用

# アクセス解析・Google 検索（本番デプロイ時に Cloudflare Pages の環境変数にも設定）
# ① GA4: https://analytics.google.com でプロパティ作成 → データストリーム → 測定ID（G-XXXX）
#    → analytics.google.com で PV・訪問者数を確認（口コミサイトと同じ仕組み）
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# ② Search Console: https://search.google.com/search-console でサイト追加
#    → 所有権確認「HTMLタグ」を選び、content の値だけを下に貼る
VITE_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ③ Search Console → サイトマップ → https://あなたのドメイン/sitemap.xml を送信
# ④ インデックス登録に数日〜数週間かかることがあります

# Supabase site_visits（フッター等の自前カウント用・Google とは別）
